# Provider selection: openai | ollama
LLM_PROVIDER=ollama

# OpenAI-compatible base URL (OpenWebUI example: http://localhost:8080/api)
OPENAI_BASE_URL=http://localhost:8080/api

# Ollama base URL (used when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434

# Optional chat completions path override (e.g. /api/chat/completions)
# Leave empty to auto-try provider-safe defaults (e.g. /chat/completions or /v1/chat/completions)
OPENAI_CHAT_COMPLETION_PATH=

# Optional bearer token for protected OpenAI-compatible endpoints
OPENAI_API_KEY=

# Default model to use for translations
DEFAULT_MODEL=translategemma:27b

# Set to "true" only when deployed behind a trusted reverse proxy (e.g. nginx)
# that sets the X-Forwarded-For header. Never set on direct-internet deployments.
TRUST_PROXY=false
